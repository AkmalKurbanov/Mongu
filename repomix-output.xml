@use "sass:math"
@use '../settings/variables' as v

@function to-rem($pixel)
  @if not math.is-unitless($pixel)
    $pixel: math.div($pixel, $pixel * 0 + 1)

  @return math.div($pixel, v.$base-fsize) * 1rem

@function to-em($pixel, $context: v.$base-fsize)
  @if not math.is-unitless($pixel)
    $pixel: math.div($pixel, $pixel * 0 + 1)

  @if not math.is-unitless($context)
    $context: math.div($context, $context * 0 + 1)

  @return math.div($pixel, $context) * 1em
</file>

<file path="src/sass/tools/_mixins.sass">
@use "sass:map"
@use '../tools/_functions' as v

$breakpoints: ('tablet': 768px, 'laptop': 1024px, 'desktop': 1440px, 'xlarge': 1920px)

@mixin media($key)
  $size: map.get($breakpoints, $key)

  @if $size
    @media (min-width: $size)
      @content

  @else
    @warn "Брекпоинт #{$key} не найден в карте!"

@mixin has-mouse
  @media (hover: hover) and (pointer: fine)
    @content

@mixin is-touch
  @media (hover: none) and (pointer: coarse)
    @content

@mixin portrait
  @media (orientation: portrait)
    @content

@mixin landscape
  @media (orientation: landscape)
    @content    

@mixin section-padding
  padding: v.to-rem(40) 0
  @include media('tablet')
    padding: v.to-rem(60) 0
  @include media('desktop')
    padding: v.to-rem(100) 0
</file>

