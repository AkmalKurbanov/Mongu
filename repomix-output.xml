<file path="src/sass/base/_base.sass">
@use '../settings/shared' as v

*
  box-sizing: border-box

html, body
  margin: 0
  height: 100%

html
  scroll-behavior: smooth
  font-size: 16px

body
  font-family: v.$ff-base
  color: v.$clr-text
  display: flex
  flex-direction: column
  line-height: 1.3
  background-color: #f9f9fb

  main
    flex: 1 0 auto

  &.scroll-locked
    overflow: hidden

h1, h2, h3
  font-weight: 700
  line-height: 1.2

.main-content
  &_inner-page
    padding-top: v.to-rem(50)

    @include v.media(tablet)
      padding-top: v.to-rem(70)


.container
  max-width: v.$container-width
  margin: 0 auto
  padding: 0 v.$container-padding
  width: 100%

  &_narrow
    max-width: v.$container-narrow-width

img
  width: 100%
  height: auto
  display: block
  object-fit: cover

.visually-hidden
  position: absolute
  width: 1px
  height: 1px
  margin: -1px
  border: 0
  padding: 0
  white-space: nowrap
  clip-path: inset(100%)
  clip: rect(0 0 0 0)
  overflow: hidden

.title-wrap
  margin-bottom: v.to-rem(30)

.title
  font-size: v.to-rem(25)
  font-weight: 600
  font-family: v.$ff-accent
  color: #111

  &_light
    color: #fff

  &_centered
    text-align: center

  @include v.media('tablet')
    font-size: v.to-rem(30)

.subtitle
  text-align: center
  color: v.$clr-accent
  font-size: v.to-rem(16)
  margin-top: v.to-rem(12)
  max-width: v.to-rem(600)
  margin-inline: auto

.logo
  display: flex
  align-items: center
  justify-content: center
  width: v.to-rem(100)
  flex-shrink: 0

  @include v.media(tablet)
    width: v.to-rem(130)

.section-padding
  padding: v.$section-padding-y

  @include v.media(desktop)
    padding: v.to-rem(60) 0

.section-bg
  background-color: #f3f1ef

.icon
  width: v.to-rem(20)
  height: v.to-rem(20)

.swiper-pagination-bullet-active
  background-color: v.$clr-accent
</file>

