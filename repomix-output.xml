  .price-card
    border-radius: v.$rad-lg
    text-align: center
    display: flex
    flex-direction: column
    row-gap: v.$space-lg
    line-height: normal
    background-color: #f3f3fb
    padding: v.$space-md
    margin-bottom: v.$space-lg
    border: 2px solid v.$clr-accent

    &__duration
