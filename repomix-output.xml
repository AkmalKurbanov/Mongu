<file path="src/sass/components/_categories-teaser.sass">
@use '../settings/shared' as v

.teaser-cat
  &__btn-wrap
    margin-top: v.$space-lg

  &__flex-wrap
    gap: v.$space-md

    &.js-slider-viewport
      
      @include v.media(tablet)
        display: grid
        grid-template-columns: repeat(6, 1fr)
        grid-auto-rows: v.to-rem(175)

      @include v.media(laptop)
        grid-auto-rows: v.to-rem(200)

      @include v.media(desktop)
        grid-auto-rows: v.to-rem(260)

  &__item
    flex: 0 0 100%
    position: relative
    border-radius: v.$rad-lg
    overflow: hidden
    aspect-ratio: 4 / 3
    
    @include v.has-mouse
      &:hover
        .teaser-cat__img img,
        .teaser-cat__desc-wrap
          will-change: transform
          transform: translateY(v.to-rem(-5))

        .teaser-cat__img img
          transform: scale(1.03)

    @include v.media(tablet)
      aspect-ratio: auto
      
      &:nth-child(1)
        grid-column: span 3 / span 3
        grid-row: span 2 / span 2

      &:nth-child(2)
        grid-column: span 3 / span 3
        grid-column-start: 4

      &:nth-child(3)
        grid-column: span 3 / span 3
        grid-column-start: 4
        grid-row-start: 2

      &:nth-child(4)
        grid-column: span 3 / span 3
        grid-row-start: 3

      &:nth-child(5)
        grid-column: span 3 / span 3
        grid-column-start: 1
        grid-row-start: 4

      &:nth-child(6)
        grid-column: span 3 / span 3
        grid-row: span 2 / span 2
        grid-column-start: 4
        grid-row-start: 3

  &__img
    height: 100%
    position: relative
    overflow: hidden

    &::after
      position: absolute
      content: ''
      width: 100%
      height: 100%
      inset: 0
      background-color: rgba(0,0,0,0.5)

    img
      height: 100%
      width: 100%
      object-fit: cover
      transition: transform .5s ease

  &__desc-wrap
    position: absolute
    color: #fff
    transition: transform .6s ease
    left: v.$space-md
    right: v.$space-md
    bottom: v.$space-md
    
    @include v.media(desktop)
      left: v.$space-xl
      right: v.$space-xl
      bottom: v.$space-xl

  &__icon
    width: v.to-rem(50)
    height: v.to-rem(50)
    fill: #fff
    margin-bottom: v.to-rem(-14)

  &__title
    font-weight: 600
    font-size: v.$fz-xl
    text-transform: uppercase
    line-height: normal
    display: flex
    align-items: flex-end
    gap: v.$space-xs

    @include v.media(tablet)
      font-size: v.$fz-md

    @include v.media(laptop)
      font-size: v.$fz-xl

  &__desc
    margin-top: v.$space-sm

    @include v.media(tablet)
      font-size: v.$fz-md
    
    @include v.media(laptop)
      font-size: v.$fz-base


  &__link
    position: absolute
    width: 100%
    height: 100%
    inset: 0

  .slider
    padding: 0
    &__nav
      @include v.media(tablet)
        display: none
</file>

<file path="src/sass/components/_header.sass">
@use '../settings/shared' as v

@mixin flex-center
  display: flex
  align-items: center

@mixin pseudo-element
  &::after
    position: absolute
    content: ''
    width: 100%
    height: v.to-rem(10)
    top: 100%
    left: 0

@mixin dropdown-menu
  display: flex
  flex-direction: column
  position: absolute
  top: calc(100% + v.to-rem(15))
  pointer-events: none
  opacity: 0
  transition: top v.$tr-base, opacity v.$tr-base
  z-index: 10
  width: max-content
  background-color: #fff
  list-style: none
  border-radius: v.$rad-sm
  box-shadow: v.$shadow-sm
  overflow: hidden

  .header__nav-sublink,
  .header__callback-link
    @include flex-center
    color: v.$clr-accent
    padding: v.$space-xs v.$space-md
    text-decoration: none
    text-align: left
    column-gap: v.$space-xs
    transition: background-color v.$tr-fast, color v.$tr-fast

    .icon
      transition: color v.$tr-base

    @include v.has-mouse
      &:hover
        color: #fff
        background-color: rgba(v.$clr-accent, .5)

@mixin dropdown-active
  opacity: 1
  pointer-events: auto
  top: calc(100% + v.to-rem(5))

.header
  width: calc( 100% - (v.$space-md * 2) )
  z-index: 4
  position: fixed
  top: v.$space-md
  left: 0
  right: 0
  margin: 0 auto
  opacity: 0
  transition: opacity v.$tr-fast 
  transition-delay: .25s

  &__container
    display: flex
    align-items: stretch
    justify-content: space-between
    column-gap: v.$space-xs
    transition: background-color v.$tr-base, max-width v.$tr-base, padding v.$tr-base
    border-radius: v.$rad-sm
    height: v.to-rem(50)

    @include v.media(tablet)
      box-shadow: v.$shadow-sm

    &.container
      padding: 0
      @include v.media(tablet)
        padding: 0 v.$space-md

  .header__logo
    @include flex-center

    @include v.media(tablet)
      width: v.to-rem(30)

    @include v.media(laptop)
      width: auto

  .logo
    color: #fff
    display: flex

    @include v.media(desktop)
      width: v.to-rem(130)
      height: v.to-rem(40)

    .hidden-elem
      @include v.media(tablet)
        display: none

      @include v.media(laptop)
        display: flex

    svg
      width: 100%
      height: 100%
      transition: color v.$tr-fast

  &__nav
    display: none

    @include v.media(tablet)
      display: flex
      justify-content: center
      flex-grow: 1

  &__nav-list
    column-gap: v.$space-xs

    @include v.media(tablet)
      column-gap: v.$space-md
      display: flex
      align-items: stretch
      list-style: none
      justify-content: space-around

  &__nav-item
    @include flex-center
    gap: v.$space-xs
    position: relative
    flex-direction: column

    @include pseudo-element

    @include v.has-mouse
      &:hover
        .header__nav-sublist
          @include dropdown-active

  &__nav-link
    @include flex-center
    text-decoration: none
    font-weight: 500
    color: #fff
    transition: color v.$tr-base
    height: 100%

    @include v.media(tablet)
      font-size: v.$fz-sm

    @include v.media(laptop)
      font-size: v.$fz-md

    @include v.media(desktop)
      font-size: v.$fz-lg

    @include v.has-mouse
      &:hover
        color: #ddd

  &__nav-sublist
    @include dropdown-menu
    left: 0

  &__nav-subitem
    &:after
      display: none

  &__nav-sublink
    text-transform: inherit

  &__controls
    @include flex-center
    gap: v.$space-xs

    .hamburger
      @include flex-center
      cursor: pointer
      color: #fff
      @include v.media(tablet)
        display: none

  &__btn
    width: v.to-rem(85)
    transition: min-width v.$tr-fast

    @include v.media(laptop)
      width: v.to-rem(110)

  &__btn, &__callback-wrap
    @include flex-center
    background-color: v.$clr-accent
    color: #fff
    border-radius: v.$rad-sm
    border: v.to-rem(1) solid #fff
    cursor: pointer
    position: relative
    height: v.to-rem(30)
    font-size: v.$fz-xs
    padding: 0 v.$space-xs
    white-space: nowrap
    transition: font-size v.$tr-base

    @include v.media(laptop)
      font-size: v.$fz-md

  &__callback
    height: 100%
    @include flex-center
    position: relative
    @include pseudo-element

    &:hover
      .header__callback-list
        @include dropdown-active

  &__callback-list
    @include dropdown-menu
    right: 0

  &__callback-item
    .icon
      &_headphones
        width: v.to-rem(24)
        height: v.to-rem(24)

  &_inside
    .header__container
      padding: 0 v.$space-md

  &_inside,
  &_reduced
    .header__container
      background-color: #f9f9fb
      box-shadow: v.$shadow-sm

    .logo
      color: #000
    .hamburger
      color: v.$clr-accent

    .header__nav-link
      color: v.$clr-text
      @include v.has-mouse
        &:hover
          color: v.$clr-accent-darker

  &_reduced
    opacity: 1 
    .header__container
      max-width: calc( v.to-rem(1200) - (v.$container-padding * 3) )
      padding: 0 v.$space-md

    .header__btn
      // min-width: auto
      @include v.media(laptop)
        font-size: v.$fz-xs

    .logo
      flex-shrink: 0

      @include v.media(desktop)
        width: v.to-rem(100)
        height: v.to-rem(30)

    .header__nav-link
      text-transform: inherit

  &_glued
    opacity: 1
</file>

<file path="src/sass/components/_hero.sass">
@use '../settings/shared' as v

@mixin wh
  width: 100%
  height: 100%

.hero
  height: 100svh
  position: relative

  @include v.is-touch
    @include v.landscape
      height: auto
      padding-bottom: v.$space-xl

  &::before
    @include wh
    position: absolute
    content: ''
    inset: 0
    background-color: rgba(0,0,0,0.5)
    z-index: 2

  &__poster
    @include wh
    object-fit: cover

    @include v.media(tablet)
      aspect-ratio: 800 / 1100

    @include v.media(laptop)
      aspect-ratio: 1440 / 900

    @include v.media(desktop)
      aspect-ratio: 1920 / 1080

    @include v.landscape
      aspect-ratio: 1440 / 900

  &__media,
  &__video
    @include wh
    position: absolute
    inset: 0

    img
      @include wh
      object-fit: cover
      object-position: bottom right

  &__content
    position: relative
    z-index: 3
    height: 100%
    display: flex
    padding-top: v.to-rem(70)

    @include v.media(tablet)
      padding-top: v.to-rem(160)

      @include v.landscape
        padding-top: v.to-rem(80)

    @include v.media(laptop)
      @include v.has-mouse
        @include v.landscape
          padding-bottom: v.to-rem(120)
          align-items: flex-end

  &__title
    font-family: v.$ff-accent
    color: #fff
    font-size: v.$fz-hero
    line-height: v.to-rem(40)
    font-weight: 400

    @include v.media(tablet)
      font-size: v.to-rem(60)
      line-height: v.to-rem(60)

      @include v.is-touch
        @include v.landscape
          font-size: v.to-rem(40)
          line-height: v.to-rem(40)

  &__title-accent
    font-style: italic

  &__subtitle
    text-transform: uppercase
    color: #fff
    line-height: 1.6
    font-weight: 500
    max-width: v.to-rem(360)
    width: 100%

  &__subtitle,
  &__btn-links
    margin-top: v.$space-lg

  &__btn-links
    display: flex
    flex-direction: column
    align-items: flex-start
    gap: v.$space-md

    @include v.media(desktop)
      flex-direction: row

  &__btn
    justify-content: space-between

    &_accent
      min-width: v.to-rem(185)

      @include v.media(laptop)
        min-width: v.to-rem(250)

    &_light
      min-width: v.to-rem(235)

      @include v.media(laptop)
        min-width: v.to-rem(310)

  &_inside
    height: v.to-rem(450)
    display: flex
    justify-content: flex-end
    flex-direction: column

    .hero
      &__content
        padding-bottom: v.$space-xl
        height: auto
        width: 100%
</file>

