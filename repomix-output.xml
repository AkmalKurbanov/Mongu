  &__grid
    padding: v.$space-xl 0
    gap: v.$space-sm

    @include v.media(tablet)
      gap: v.$space-lg
      flex-wrap: wrap
    
    @include v.media(laptop)
      gap: v.$space-sm
    
    @include v.media(desktop)
      gap: v.$space-lg

  &__item
    width: 100%

    @include v.media(tablet)
      width: calc( (50% - (1 * v.$space-lg) / 2) )

    @include v.media(laptop)
      width: calc( (100% - (3 * v.$space-sm)) / 4 )
    
    @include v.media(desktop)
      width: calc( (100% - (3 * v.$space-lg)) / 4 )

.teaser-card
  position: relative
  overflow: hidden
  border-radius: v.$rad-md
  transition: transform v.$tr-base
  will-change: transform
  background-color: #fff
  box-shadow: v.$shadow-md

  &__img
    overflow: hidden
    aspect-ratio: 4/3

    img
      transition: transform v.$tr-base
      height: 100%

  &__desc
    padding: v.$space-md

    .badges
      margin-bottom: v.$space-sm

      &__badge_category
        z-index: 2

  &__title
    margin-bottom: v.$space-xs
    font-size: v.$fz-base
    font-weight: 500

  p
    color: #6b6b73
    font-size: v.$fz-md
    margin-bottom: v.$space-sm
    font-weight: 500
    line-height: 1.4

  &__more
    display: inline-flex
    align-items: center
    justify-content: center
    gap: v.$space-xs
    cursor: pointer
    color: v.$clr-secondary
    
    .icon
      transition: transform v.$tr-base

  &__link
    position: absolute
    width: 100%
    height: 100%
    z-index: 1

  @include v.has-mouse
    &:hover
      transform: translateY(v.to-rem(-5))
      .teaser-card__img
        img
          transform: scale(1.02)

      .teaser-card__more
        .icon
          transform: translateX(v.to-rem(5))
</file>

