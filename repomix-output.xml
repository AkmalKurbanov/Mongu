<file path="src/sass/components/_header.sass">
@use '../settings/shared' as v

.header
  padding: v.to-rem(10) 0
  width: 100%
  z-index: 4
  position: fixed
  top: 0
  transition: background-color .2s ease-in-out

  &__container
    display: flex
    align-items: center
    justify-content: space-between

  .logo
    color: #fff

    @include v.media(tablet)
      width: v.to-rem(130)
      height: v.to-rem(50)

    svg
      width: 100%
      height: 100%
      object-fit: cover
      transition: color .2s ease-in-out

  nav
    display: none

    position: relative

    @include v.media(desktop)
      display: flex
      justify-content: center
      flex-grow: 1

    ul
      @include v.media(desktop)
        display: flex
        align-items: center
        list-style: none
        column-gap: v.to-rem(30)
        position: relative

      li
        display: flex
        align-items: center
        gap: v.to-rem(5)

        a
          text-decoration: none
          transition: color v.$tr-base
          text-transform: uppercase
          font-weight: 500
          color: #fff

          @include v.media(desktop)
            font-size: v.to-rem(16)

            @include v.has-mouse
              &:hover
                color: #ddd

        ul
          width: 100%
          position: absolute
          background-color: #fff
          left: 50%
          transform: translateX(-50%)
          border-radius: v.to-rem(12)
          top: 100%
          pointer-events: none
          opacity: 0
          transition: top .2s ease, opacity .2s ease
          padding: v.to-rem(16)

          &::before
            content: ''
            position: absolute
            bottom: 100%
            left: 0
            width: 100%
            height: v.to-rem(10)
            background: transparent
            cursor: pointer

          li
            a
              color: v.$clr-accent
              @include v.has-mouse
                &:hover
                  color: v.$clr-accent-darker

        @include v.has-mouse
          &:hover
            ul
              top: calc( 100% + 10px )
              opacity: 1
              pointer-events: inherit

  &__controls
    display: flex
    align-items: stretch
    flex-shrink: 0
    gap: v.to-rem(5)
    height: v.to-rem(30)
    
    @include v.media(tablet)
      height: v.to-rem(35)


    @include v.media(tablet)
      gap: v.to-rem(10)

    .hamburger
      background: none
      border: none
      outline: none
      display: flex
      align-items: center
      justify-content: center
      cursor: pointer
      color: #fff
      margin-left: v.to-rem(5)
      
      @include v.media(desktop)
        display: none

      .icon
        width: v.to-rem(24)
        height: v.to-rem(24)

  .btn,
  &__callback
    background-color: v.$clr-accent
    color: #fff
    border-radius: v.to-rem(8)
    border: 1px solid #fff
    display: flex
    align-items: center
    padding: 0 v.to-rem(5)
    cursor: pointer
    position: relative

    @include v.media(tablet)
      padding: 0 v.to-rem(8)

  .btn
    font-size: v.to-rem(12px)
    
    @include v.media(tablet)
      font-size: v.to-rem(14px)

  &__callback

    &::after
      position: absolute
      content: ''
      width: 100%
      height: 100%
      background-color: transparent
      height: 10px
      top: 100%
      left: 0

    ul
      list-style: none
      background-color: #fff
      position: absolute
      right: 0
      top: 100%
      width: max-content
      border-radius: v.to-rem(10)
      overflow: hidden
      pointer-events: none
      opacity: 0
      transition: opacity v.$tr-base, top v.$tr-base
      border: 1px solid v.$clr-accent

      li
        position: relative

        &::after
          position: absolute
          content: ''
          width: calc( 100% - 20px )
          left: 50%
          transform: translateX(-50%)
          height: 1px
          background-color: v.$clr-accent
          top: 100%
          z-index: 1

        a
          color: v.$clr-accent
          padding: v.to-rem(5.5) v.to-rem(10)
          text-decoration: none
          transition: color v.$tr-base, background-color v.$tr-base
          display: flex
          gap: v.to-rem(5)
          align-items: center

          @include v.has-mouse
            &:hover
              color: v.$clr-accent-darker
              background-color: #eee

    &:hover
      ul
        opacity: 1
        pointer-events: inherit
        top: calc( 100% + 10px )

    .icon
      width: v.to-rem(24)
      height: v.to-rem(24)

  &_bg
    background-color: #f9f9fb
    box-shadow: 0 10px 26px rgba(12,21,38,.2)
    nav
      ul
        li
          a
            color: v.$clr-text

            @include v.has-mouse

              &:hover
                color: v.$clr-accent-darker

    .hamburger
      color: v.$clr-accent
      
    .logo
      color: #000
    
    .header__callback
      ul
        top: calc( 100% + v.to-rem(20) )
      
      &::after
        height: v.to-rem(30)

      &:hover
        ul
          top: calc( 100% + v.to-rem(15) )
          @include v.media(tablet)
            top: calc( 100% + v.to-rem(25) )
  
    nav ul li ul
      top: calc( 100% + v.to-rem(20) )
  
      &::before
        height: v.to-rem(30)
        
    nav ul li
      &:hover
        ul
          top: calc( 100% + v.to-rem(30) )
</file>

<file path="src/sass/components/_menu.sass">
@use '../settings/shared' as v

.menu
  position: fixed
  width: 100%
  height: 100%
  inset: 0
  backdrop-filter: blur(10px)
  z-index: 5
  transition: opacity v.$tr-base
  pointer-events: none
  opacity: 0

  &_is-open
    opacity: 1
    pointer-events: inherit
    .menu__sidebar
      top: 0

  &__sidebar
    position: absolute
    height: 100%
    background-color: #fff
    top: 100%
    transition: top v.$tr-base
    transition-delay: .2s
    width: 100%
    display: flex
    align-items: center
    padding: v.to-rem(70) 0 v.to-rem(30)

  &__close
    position: absolute
    top: v.to-rem(16)
    right: v.to-rem(16)
    width: v.to-rem(40)
    height: v.to-rem(40)
    color: #fff
    background-color: #000
    border-radius: 100%
    display: flex
    align-items: center
    justify-content: center
    cursor: pointer

    .icon
      width: 100%
      height: 100%

  nav
    display: flex
    width: 100%
    height: 100%
    overflow-y: auto

    ul
      display: flex
      flex-direction: column
      width: 100%

      @include v.media(tablet)
        justify-content: flex-start
        display: inline-flex
        width: auto

      li
        list-style: none
        margin-bottom: v.to-rem(10)
        position: relative
        padding: 0 v.to-rem(16)

        @include v.media(tablet)
          justify-content: flex-start

        &:has(ul)
          display: inline-flex
          align-items: center
          flex-wrap: wrap
          justify-content: space-between

        &:last-child
          margin-bottom: 0

        a
          text-decoration: none
          color: v.$clr-text
          transition: color v.$tr-base
          font-weight: 500
          font-size: v.to-rem(30)
          line-height: normal
          display: block

          @include v.has-mouse
            &:hover
              color: v.$clr-accent
              
        ul
          height: 0
          transition: height v.$tr-base-in-out, opacity v.$tr-base-in-out
          overflow: hidden
          opacity: 0
          width: 100%  

          li
            margin-top: v.to-rem(10)
            display: block
            margin-bottom: 0

            a
              font-size: v.to-rem(16)
              display: inline-block

        button
          flex-grow: 1
          display: flex
          justify-content: flex-end
          align-items: center
          border: none
          outline: none
          cursor: pointer
          background: none
          z-index: 20

          @include v.media(tablet)
            flex-grow: 0

          .icon
            width: v.to-rem(32)
            height: v.to-rem(32)
            transition: color v.$tr-base
            top: v.to-rem(6)
            pointer-events: none
            right: v.to-rem(8)

        &.is-droped
          ul
            height: auto
            opacity: 1
</file>

<file path="src/sass/components/_hero.sass">
@use '../settings/shared' as v
.hero
  height: 100svh
  position: relative

  @include v.is-touch
    @include v.landscape
      height: auto
      padding-bottom: v.to-rem(30)
    

  &::before
    position: absolute
    content: ''
    width: 100%
    height: 100%
    inset: 0
    background-color: rgba(0,0,0,0.4)
    background-color: rgba(0,0,0,0.5)
    z-index: 2

  &__media,
  &__poster,
  &__video
    position: absolute
    width: 100%
    height: 100%
    inset: 0
  
    img
      object-fit: cover
      object-position: bottom right
      height: 100%
      width: 100%
  

  &__content
    position: relative
    z-index: 3
    height: 100%
    display: flex
    padding-top: v.to-rem(70)

    @include v.media(tablet)
      padding-top: v.to-rem(160)
      @include v.landscape
        padding-top: v.to-rem(80)

    @include v.media(laptop)
      @include v.has-mouse
        @include v.landscape
          padding-bottom: v.to-rem(120)
          align-items: flex-end

    h1
      font-family: v.$ff-accent
      color: #fff
      font-size: v.to-rem(35)
      line-height: v.to-rem(40)
      font-weight: 400
      
      @include v.media(tablet)
        font-size: v.to-rem(60)
        line-height: v.to-rem(60)

      span
        font-style: italic
        font-weight: 400

  &__subtitle
    text-transform: uppercase
    color: #fff
    line-height: 1.6
    font-weight: 600
    max-width: v.to-rem(360)
    width: 100%
  
  &__subtitle,
  &__btn-links
    margin-top: v.to-rem(20)
  
  &__btn-links
    display: flex
    flex-direction: column
    align-items: flex-start
    gap: v.to-rem(16)

    .btn
      padding: v.to-rem(10px) v.to-rem(18px)
      font-size: v.to-rem(13)
      @include v.media(laptop)
        padding: v.to-rem(16px) v.to-rem(32px)
        font-size: v.to-rem(16)

    @include v.media(desktop)
      flex-direction: row

  &_inside
    height: v.to-rem(400)
    display: flex
    justify-content: flex-end
    flex-direction: column

    @include v.media(tablet)
      height: v.to-rem(500)

    .hero
      &__content
        padding-bottom: v.to-rem(40)
        height: auto
        width: 100%
</file>

