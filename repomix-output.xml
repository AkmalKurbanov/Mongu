<file path="src/sass/components/_about-section.sass">
@use '../settings/shared' as v

.about-section
  .title
    @include v.media(laptop)
      text-align: left

  &__flex-container
    display: flex
    flex-direction: column
    gap: v.to-rem(30)
    margin: 0 auto
    text-align: center

    @include v.media(laptop)
      flex-direction: row-reverse
      justify-content: center
      align-items: flex-start
      text-align: left

    @include v.media(tablet)
      justify-content: space-between      

  &__desc
    max-width: v.to-rem(500)
    width: 100%
    margin: 0 auto

    @include v.media(laptop)
      flex-shrink: 1
      flex-basis: v.to-rem(300)
      margin-left: 0

  &__link
    text-transform: uppercase
    text-decoration: none
    font-weight: 600
    margin-top: v.to-rem(20)
    display: inline-flex
    align-items: center
    transition: color v.$tr-base
    color: v.$clr-text

    .icon
      transition: transform v.$tr-base

    @include v.has-mouse
      &:hover
        color: v.$clr-accent
        .icon
          transform: translateX(3px)

  .features
    display: flex
    flex-wrap: wrap
    justify-content: center
    column-gap: v.to-rem(10)
    row-gap: v.to-rem(30)
    text-align: center
    list-style: none    
    margin: 0 auto
    max-width: v.to-rem(350)    
    width: 100%

    @include v.media(tablet)
      max-width: v.to-rem(820)  
      column-gap: 0

    &__item
      width: calc( 50% - 5px )
      color: v.$clr-accent
      @include v.media(tablet)
        width: calc((100% - (4 * v.to-rem(10))) / 5)
        border-right: v.to-rem(1) solid v.$clr-accent 
        padding: 0 v.to-rem(5)
          
        &:last-child
          border: none

      .icon
        width: v.to-rem(50)
        height: v.to-rem(50)
        fill: v.$clr-accent

      h3
        font-size: v.to-rem(13)
        font-weight: 500
        text-transform: uppercase
        color: v.$clr-accent
        margin-bottom: v.to-rem(5)
        
        @include v.media(tablet)
          font-size: v.to-rem(16)

      p
        font-weight: 500
        font-size: v.to-rem(12)
        
        @include v.media(tablet)
          font-size: v.to-rem(14)
</file>

<file path="src/sass/components/_accordion.sass">
@use '../settings/shared' as v

.accordion
  &__content
    display: grid
    grid-template-rows: 0fr
    transition: grid-template-rows .2s ease-out
    overflow: hidden

  &__item
    border-bottom: 1px solid #e2e2e9
    padding: v.to-rem(10) 0
    

